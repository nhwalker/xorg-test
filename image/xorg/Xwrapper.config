# Xorg runs WITHOUT root rights: as the "desktop" user it opens
# /dev/dri/* and /dev/input/* by group permission (container groups are
# gid-aligned to the host's device nodes at boot by align-device-groups.sh),
# acquires DRM master as the first opener of an otherwise-unused GPU, and
# inherits tty1 from systemd (TTYPath= chowns it to the service user;
# startx passes -keeptty). Xorg still tries logind device handover first
# and falls back to these direct opens.
#
# Troubleshooting escape hatch: if X cannot open devices on your host,
# set needs_root_rights = yes to restore root-Xorg behavior.
allowed_users = anybody
needs_root_rights = no
